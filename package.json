{
    "name": "contracts",
    "scripts": {
        "install": "forge install",
        "build": "forge build",
        "build:zk-verifiers": "pnpm run hardhat compile",
        "typechain:generate": "pnpm run build && pnpm run typechain --target=ethers-v6 ./out/CSUC.sol/CSUC.json ./out/CurvyAggregator.sol/CurvyAggregator.json ./out/CurvyAggregator_CSUC_ActionHandler.sol/CurvyAggregator_CSUC_ActionHandler.json --out-dir=./generated/types && cp -r ./generated/types ./sdk",
        "cleanup": "rm -rf cache cache_hardhat out artifacts snapshots",
        "deploy:preparation": "pnpm run cleanup && source .env && mkdir -p ./deployments/$CHAIN_NAME && rm -rf ./deployments/$CHAIN_NAME/*.address",
        "simulate:deploy:csuc": "pnpm run cleanup && source .env && forge script ./script/CSUC_Deploy.s.sol:CSUC_Deploy_Script --rpc-url $RPC_URL",
        "deploy:csuc": "pnpm run simulate:deploy:csuc --broadcast --verify",
        "deploy:zk-verifiers": "yarn hardhat run ./zk-verifiers/script/deploy.s.ts",
        "simulate:deploy:aggregator": "yarn cleanup && source .env && forge script ./script/CurvyAggregator_Deploy.s.sol:CurvyAggregator_Deploy_Script --rpc-url $RPC_URL",
        "deploy:aggregator": "yarn simulate:deploy:aggregator --broadcast --verify",
        "simulate:integration:csuc-aggregator": "yarn cleanup && source .env && forge script ./script/Integration_Deposit_To_Aggregator_From_CSUC.s.sol:Integration_Deposit_To_Aggregator_From_CSUC_Script --rpc-url $RPC_URL",
        "deploy:integration:csuc-aggregator": "yarn simulate:integration:csuc-aggregator --broadcast --verify",
        "simulate:deploy:all": "yarn deploy:preparation && yarn simulate:deploy:csuc && yarn deploy:zk-verifiers && yarn simulate:deploy:aggregator && yarn simulate:integration:csuc-aggregator",
        "deploy:all": "yarn deploy:preparation && yarn deploy:csuc && yarn deploy:zk-verifiers && yarn deploy:aggregator && yarn deploy:integration:csuc-aggregator",
        "sanity-checks:csuc-wrap": "source .env && forge script ./script/sanity-checks/CSUC_Wrap.s.sol:CSUC_Wrap_Script --rpc-url $RPC_URL --broadcast --verify",
        "sanity-checks:csuc-transfer": "source .env && forge script ./script/sanity-checks/CSUC_Transfer.s.sol:CSUC_Transfer_Script --rpc-url $RPC_URL --broadcast --verify",
        "sanity-checks:csuc-unwrap": "source .env && forge script ./script/sanity-checks/CSUC_Unwrap.s.sol:CSUC_Unwrap_Script --rpc-url $RPC_URL --broadcast --verify",
        "sanity-checks:csuc-aggregator": "source .env && forge script ./script/sanity-checks/Integration_CSUC_Aggregator.s.sol:Integration_CSUC_Aggregator_Script --rpc-url $RPC_URL",
        "sanity-checks:all": "yarn sanity-checks:csuc-wrap && yarn sanity-checks:csuc-transfer && yarn sanity-checks:csuc-unwrap",
        "start:blockchain": "npx hardhat node --port 8545"
    },
    "dependencies": {
        "@nomicfoundation/hardhat-foundry": "^1.1.1",
        "@nomiclabs/hardhat-waffle": "^2.0.6",
        "@openzeppelin/upgrades-core": "^1.44.1",
        "dotenv": "^16.4.5",
        "poseidon-solidity": "^0.0.5"
    },
    "devDependencies": {
        "@applied-crypto/merkletree": "^0.1.2",
        "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
        "@nomicfoundation/hardhat-ethers": "^3.0.0",
        "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
        "@nomicfoundation/hardhat-toolbox": "^4.0.0",
        "@nomicfoundation/hardhat-verify": "^2.0.0",
        "@typechain/ethers-v6": "^0.5.0",
        "@typechain/hardhat": "^9.0.0",
        "@types/chai": "^4.2.0",
        "@types/mocha": ">=9.1.0",
        "@types/node": ">=18.0.0",
        "@zk-kit/eddsa-poseidon": "^0.10.0",
        "@zk-kit/imt": "^2.0.0-beta.1",
        "chai": "^4.2.0",
        "circomlib": "^2.0.5",
        "circomlibjs": "^0.1.7",
        "ethers": "^6.4.0",
        "hardhat": "^2.14.0",
        "hardhat-gas-reporter": "^1.0.8",
        "poseidon-lite": "^0.2.0",
        "prettier": "^3.2.5",
        "prettier-plugin-solidity": "^1.3.1",
        "snarkjs": "^0.7.3",
        "solidity-coverage": "^0.8.0",
        "ts-node": ">=8.0.0",
        "typechain": "^8.3.0",
        "typescript": ">=4.5.0"
    }
}
