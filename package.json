{
  "name": "contracts",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "deploy:MetaErc20Wrapper": "hardhat ignition deploy ./ignition/modules/MetaErc20Wrapper.ts --network localhost",
    "deploy:CurvyAggregator": "hardhat ignition deploy ./ignition/modules/CurvyAggregator.ts --network localhost",
    "deploy:all": "npm run deploy:MetaErc20Wrapper && npm run deploy:CurvyAggregator",
    "test": "npm run deploy:all && vitest run"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.0.3",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.0",
    "@types/node": "^22.18.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.0.6",
    "typescript": "~5.8.3",
    "viem": "^2.36.0"
  },
  "dependencies": {
    "@types/mocha": "^10.0.10",
    "chai": "^6.0.1",
    "chai-as-promised": "^8.0.2",
    "chai-string": "^1.6.0",
    "hardhat-dependency-compiler": "^1.2.1",
    "poseidon-solidity": "^0.0.5",
    "vitest": "^3.2.4"
  }
}
